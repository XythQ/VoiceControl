<?xml version="1.0"?>
<!--
    ServerConfig.xml - sherpa-server configuration only.

    This file is read by the precompiled sherpa-server.exe binary at startup.
    Do not rename or move - the path is hardcoded in the executable.

    === Fields ===
      EngineType: must be "kokoro" for the Kokoro TTS engine.
      ModelDirectory: relative path from sherpa-server.exe to the Kokoro model folder.
                      Resolved as: <exe_dir>/<ModelDirectory>
                      Default points to ../../Resources/KokoroSherpa (up two levels from bin/).
      ModelFile: name of the ONNX model file inside ModelDirectory.
      TokensFile: name of the token vocabulary file inside ModelDirectory.
      VoicesFile: name of the voice weights binary inside ModelDirectory.

    === VoiceMap ===
      Each <Voice> maps a user-friendly alias to a numeric ID used by sherpa-server.
      The "id" attribute is the positional index in the voices.bin file.
      Aliases are what you use in personalities.xml (e.g., af_heart, am_adam).

      Voice ID ranges:
        0-10   = American Female (af_*)
        11-19  = American Male (am_*)
        20-23  = British Female (bf_*)
        24-27  = British Male (bm_*)
        28     = Spanish Female (ef_*)
        29-30  = Spanish Male (em_*)
        31     = Finnish Female (ff_*)
        32-33  = Hindi Female (hf_*)
        34-35  = Hindi Male (hm_*)
        36     = Irish Female (if_*)
        37-40  = Japanese Female (jf_*)
        41     = Japanese Male (jm_*)
        42-45  = Chinese Female (zf_*)
        46-49  = Chinese Male (zm_*)
        50     = Irish Male (im_*)
        51     = Polish Female (pf_*)
        52-53  = Polish Male (pm_*)

      NOTE: IDs 28-53 (accent/foreign voices) are from official v1.0 documentation.
            Verify with /audition endpoint after swapping to v1.0 model - ordering may differ.

    All other mod settings live in modconfig.xml.
-->
<ServerConfig>
    <EngineType>kokoro</EngineType>
    <ModelDirectory>..\..\Resources\KokoroSherpa</ModelDirectory>
    <ModelFile>model.onnx</ModelFile>
    <TokensFile>tokens.txt</TokensFile>
    <VoicesFile>voices.bin</VoicesFile>

    <VoiceMap>
        <!-- Simple name aliases (user-friendly) -->
        <Voice alias="Adam" id="11" />
        <Voice alias="Michael" id="16" />
        <Voice alias="Fenrir" id="14" />
