    <Voice alias="am_santa"   file="M4.json" />

    <!-- American Female voices - F1 to F5 -->
    <Voice alias="af_alloy"   file="F1.json" />
    <Voice alias="af_aoede"   file="F2.json" />
    <Voice alias="af_bella"   file="F3.json" />
