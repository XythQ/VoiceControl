<?xml version="1.0"?>
<!--
    SupertonicConfig.xml - supertonic-server configuration only.

    This file is read by the precompiled supertonic-server.exe binary at startup.
    Do not rename or move - the path is hardcoded in the executable.

    === Fields ===
      ModelDirectory: relative path from supertonic-server.exe to the Supertonic model folder.
                      Resolved as: <exe_dir>/<ModelDirectory>
                      Default points to ../../Resources/Supertonic (up two levels from bin/).
      OnnxSubdir: subfolder inside ModelDirectory containing the 4 ONNX models.
      UnicodeIndexer: filename of the unicode_indexer.json inside OnnxSubdir.
      VoiceStyleDir: directory containing voice style JSON files (relative to exe).

      TotalStep: denoising steps, 5 (fast) to 12 (high quality), default 6.
      Speed: default speech speed factor, 0.7 (slow) to 2.0 (fast), default 1.05.

      IntraOpNumThreads: ORT intra-op threads; 0 or blank means clamp(ProcessorCount, 2, 4).
      GraphOptimization: all | extended | basic | none.
      EnableMemoryPattern: true | false - reduces alloc overhead per call.

    === VoiceMap ===
      Each <Voice> maps a user-friendly alias to a JSON voice style file.
      Aliases are what you use in personalities.xml (e.g., Alex, Sarah).
-->
<SupertonicConfig>

  <!-- Path to the Supertonic model root (relative to bin/SupertonicServer/) -->
  <ModelDirectory>..\..\Resources\Supertonic</ModelDirectory>

  <!-- Subfolder containing the 4 ONNX models -->
  <OnnxSubdir>onnx</OnnxSubdir>

  <!-- Unicode indexer filename inside OnnxSubdir -->
  <UnicodeIndexer>unicode_indexer.json</UnicodeIndexer>

  <!-- Directory containing voice style JSON files (relative to bin/SupertonicServer/) -->
  <VoiceStyleDir>..\..\Resources\Supertonic\voice_styles</VoiceStyleDir>

  <!-- Denoising steps: 5 (fast) to 12 (high quality), default 6 -->
  <TotalStep>6</TotalStep>

  <!-- Default speech speed factor: 0.7 (slow) to 2.0 (fast), default 1.05 -->
  <Speed>1.05</Speed>

  <!-- ORT intra-op threads: 0 or blank means clamp(ProcessorCount, 2, 4) -->
  <IntraOpNumThreads>4</IntraOpNumThreads>

  <!-- Graph optimization: all | extended | basic | none -->
  <GraphOptimization>all</GraphOptimization>

  <!-- Enable memory pattern pooling (reduces alloc overhead per call) -->
  <EnableMemoryPattern>true</EnableMemoryPattern>

  <!-- Voice alias to JSON file mapping -->
  <!-- Native Supertonic aliases (simple names) -->
  <VoiceMap>
    <Voice alias="harley"    file="harley.json" />
    <Voice alias="Alex"      file="M1.json" />
    <Voice alias="James"     file="M2.json" />
    <Voice alias="Robert"    file="M3.json" />
    <Voice alias="Sam"       file="M4.json" />
