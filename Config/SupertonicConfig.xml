    <Voice alias="Lily"      file="F2.json" />
    <Voice alias="Jessica"   file="F3.json" />
    <Voice alias="Olivia"    file="F4.json" />
    <Voice alias="Emily"     file="F5.json" />

    <!-- Kokoro voice aliases (from personalities.xml) - mapped to Supertonic presets -->
    <!-- American Male voices - M1 to M5 -->
    <Voice alias="am_adam"    file="M1.json" />
